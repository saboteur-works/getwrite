{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "skipLibCheck": true,
        "types": ["node", "react"]
    },
    "include": [
        "stories/**/*.ts",
        "stories/**/*.tsx",
        "components/**/*.ts",
        "components/**/*.tsx",
        "src/types/**/*.d.ts",
        "e2e/**/*.ts",
        "e2e/**/*.tsx"
    ],
    "exclude": ["node_modules"]
}
