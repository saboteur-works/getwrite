{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "deny": ["Read(./.specify/**)", "Read(./.github/agents/**)"]
    },
    "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/require-plan-approval.sh\"" }
        ]
      }
    ]
  }
}
