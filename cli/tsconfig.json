{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@gw/core": ["../frontend/src/lib/core.ts"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
