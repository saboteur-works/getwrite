{
    "id": "article",
    "name": "Article",
    "description": "Short-form article project type with drafts and references.",
    "folders": [
        { "name": "Workspace", "special": true },
        {
            "name": "References",
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        },
        { "name": "Sources" },
        { "name": "Ideas" }
    ],
    "defaultFolders": [
        {
            "name": "Articles",
            "folder": "Workspace",
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        },
        {
            "name": "Article 1",
            "folder": "Articles"
        },
        {
            "name": "Fact Checking",
            "folder": "References",
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        },
        {
            "name": "Interviews & Transcripts",
            "folder": "Sources",
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        }
    ],
    "editorConfig": {
        "headings": {
            "h1": {
                "fontSize": "40px",
                "fontWeight": "700"
            },
            "h2": {
                "fontSize": "32px",
                "fontWeight": "700"
            },
            "h3": {
                "fontSize": "24px",
                "fontWeight": "500"
            }
        }
    },
    "defaultResources": [
        {
            "folder": "Workspace",
            "name": "Article Outline",
            "type": "text",
            "template": "# Headline\n\n- Intro\n- Points\n- Conclusion\n"
        }
    ]
}
