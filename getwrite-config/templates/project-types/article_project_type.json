{
    "id": "article",
    "name": "Article",
    "description": "Short-form article project type with drafts and references.",
    "folders": [
        { "name": "Workspace", "special": true },
        { "name": "Drafts" },
        { "name": "Scheduled" },
        { "name": "Published" }
    ],
    "editorConfig": {
        "headings": {
            "h1": {
                "fontSize": "40px",
                "fontWeight": "700"
            },
            "h2": {
                "fontSize": "32px",
                "fontWeight": "700"
            },
            "h3": {
                "fontSize": "24px",
                "fontWeight": "500"
            }
        }
    },
    "defaultResources": [
        {
            "folder": "Workspace",
            "name": "Article Outline",
            "type": "text",
            "template": "# Headline\n\n- Intro\n- Points\n- Conclusion\n"
        }
    ]
}
