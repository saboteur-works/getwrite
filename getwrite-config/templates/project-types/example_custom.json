{
    "id": "example_custom",
    "name": "Example Custom",
    "description": "A minimal custom project type used as an example (stored in getwrite-config).",
    "folders": [
        { "name": "Workspace", "special": false },
        { "name": "Front Matter", "special": true },
        { "name": "Back Matter", "special": true },
        { "name": "Characters", "special": true }
    ],
    "editorConfig": {
        "headings": {
            "h1": {
                "fontSize": "40px",
                "fontWeight": "700"
            },
            "h2": {
                "fontSize": "32px",
                "fontWeight": "700"
            },
            "h3": {
                "fontSize": "24px",
                "fontWeight": "500"
            }
        }
    },
    "defaultResources": [
        {
            "folder": "Front Matter",
            "name": "Title Page",
            "type": "text",
            "template": "Title: \nAuthor: \n"
        },
        {
            "folder": "Workspace",
            "name": "Index",
            "type": "text",
            "template": "# Index\n"
        }
    ]
}
