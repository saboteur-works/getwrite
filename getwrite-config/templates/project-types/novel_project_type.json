{
    "id": "novel",
    "name": "Novel",
    "description": "Project type optimized for long-form fiction. Includes drafts, research, and assets.",
    "folders": [
        { "name": "Workspace", "special": true },
        { "name": "Story Elements" },
        { "name": "Outline" },
        { "name": "Notes" }
    ],
    "defaultFolders": [
        { "name": "Front Matter", "folder": "Workspace" },
        { "name": "Prologue", "folder": "Workspace" },
        {
            "name": "Chapters",
            "folder": "Workspace",
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        },
        {
            "name": "Chapter 1",
            "folder": "Chapters"
        },
        { "name": "Epilogue", "folder": "Workspace" },
        {
            "name": "Characters",
            "folder": "Story Elements",
            "special": true,
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        },
        {
            "name": "Items",
            "folder": "Story Elements",
            "special": true,
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        },
        {
            "name": "Locations",
            "folder": "Story Elements",
            "special": true,
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        }
    ],
    "statuses": ["Outline", "Draft", "Revised", "Polished"],
    "wordCountGoal": 80000,
    "editorConfig": {
        "headings": {
            "h1": {
                "fontSize": "40px",
                "fontFamily": "IBM Plex Serif",
                "fontWeight": "700",
                "letterSpacing": "0.01em"
            },
            "h2": {
                "fontSize": "28px",
                "fontFamily": "IBM Plex Serif",
                "fontWeight": "700"
            },
            "h3": {
                "fontSize": "20px",
                "fontFamily": "IBM Plex Serif",
                "fontWeight": "500"
            }
        },
        "body": {
            "fontFamily": "IBM Plex Serif",
            "fontSize": "15px",
            "lineHeight": "1.8",
            "paragraphSpacing": "16px"
        }
    },
    "defaultResources": [
        {
            "folder": "Chapter 1",
            "name": "Scene 1",
            "type": "text",
            "template": "# Chapter 1\n\n"
        },
        {
            "folder": "Characters",
            "name": "Character Profile",
            "type": "text",
            "template": "# Character Name\n\n- Description\n- Significance\n"
        },
        {
            "folder": "Items",
            "name": "Item Profile",
            "type": "text",
            "template": "# Item Name\n\n- Description\n- Significance\n"
        },
        {
            "folder": "Locations",
            "name": "Location Profile",
            "type": "text",
            "template": "# Location Name\n\n- Description\n- Significance\n"
        }
    ]
}
