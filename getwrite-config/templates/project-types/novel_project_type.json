{
    "id": "novel",
    "name": "Novel",
    "description": "Project type optimized for long-form fiction. Includes drafts, research, and assets.",
    "folders": [
        { "name": "Workspace", "special": true },
        { "name": "Research" },
        { "name": "Outline" },
        { "name": "Drafts" },
        { "name": "Notes" },
        { "name": "Assets" }
    ],
    "defaultFolders": [
        { "name": "Front Matter", "folder": "Workspace" },
        { "name": "Prologue", "folder": "Workspace" },
        {
            "name": "Chapters",
            "folder": "Workspace",
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        },
        { "name": "Epilogue", "folder": "Workspace" },
        {
            "name": "Characters",
            "folder": "Research",
            "special": true,
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        },
        {
            "name": "Items",
            "folder": "Research",
            "special": true,
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        },
        {
            "name": "Locations",
            "folder": "Research",
            "special": true,
            "metadataSource": {
                "isMetadataSource": true,
                "metadataInputType": "multiselect"
            }
        }
    ],
    "editorConfig": {
        "headings": {
            "h1": {
                "fontSize": "40px",
                "fontWeight": "700"
            },
            "h2": {
                "fontSize": "32px",
                "fontWeight": "700"
            },
            "h3": {
                "fontSize": "24px",
                "fontWeight": "500"
            }
        }
    },
    "defaultResources": [
        {
            "folder": "Workspace",
            "name": "Manuscript Start",
            "type": "text",
            "template": "# Chapter 1\n\n"
        },
        {
            "folder": "Characters",
            "name": "Character Profile",
            "type": "text",
            "template": "# Character Name\n\n- Description\n- Significance\n"
        },
        {
            "folder": "Items",
            "name": "Item Profile",
            "type": "text",
            "template": "# Item Name\n\n- Description\n- Significance\n"
        },
        {
            "folder": "Locations",
            "name": "Location Profile",
            "type": "text",
            "template": "# Location Name\n\n- Description\n- Significance\n"
        }
    ]
}
