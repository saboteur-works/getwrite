{
  "name": "getwrite",
  "version": "0.2.50",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "pnpm --filter getwrite-frontend dev",
    "start-dev": "pnpm --filter getwrite-frontend dev",
    "test": "pnpm --filter getwrite-frontend exec vitest",
    "electron:dev": "pnpm --filter getwrite-electron dev",
    "electron:build": "pnpm --filter getwrite-frontend build && pnpm --filter getwrite-electron build",
    "electron:package": "pnpm electron:build && pnpm --filter getwrite-electron package",
    "storybook": "pnpm --filter getwrite-frontend storybook",
    "cli": "pnpm --filter getwrite-cli exec getwrite-cli",
    "cli:build": "pnpm --filter getwrite-cli build",
    "cli:test": "pnpm --filter getwrite-cli test",
    "knip": "knip",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "@react-pdf/layout": "4.5.1",
      "@react-pdf/image": "3.0.4"
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "typescript": "^6.0.3"
  },
  "volta": {
    "node": "24.15.0",
    "pnpm": "10.28.0"
  }
}
